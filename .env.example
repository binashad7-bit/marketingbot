# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pathshalapro_bot

# API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
SENDGRID_API_KEY=your_sendgrid_api_key_here
BREVO_API_KEY=your_brevo_api_key_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=+1234567890
HUNTER_API_KEY=your_hunter_api_key_here
EMAIL_FINDER_PROVIDER=website
FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Google Sheets (for dashboard)
GOOGLE_SHEETS_CREDENTIALS=your_google_sheets_json_credentials_here
GOOGLE_SHEETS_AUTH_METHOD=auto
GOOGLE_SHEETS_OAUTH_CLIENT=your_google_sheets_oauth_client_json_or_path_here
GOOGLE_SHEETS_OAUTH_TOKEN=your_google_sheets_oauth_token_json_or_path_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Email Settings
EMAIL_PROVIDER=brevo
FROM_EMAIL=marketing@pathshalapro.net
FROM_NAME=PathshalaPro Marketing Team

# WhatsApp Settings
WHATSAPP_PROVIDER=twilio
WHATSAPP_FROM_NUMBER=+88015XXXXXXX
# When false, WhatsApp targets all qualified WhatsApp-ready leads (recommended).
# Set true to only message leads who first opened an email.
WHATSAPP_REQUIRE_EMAIL_OPEN=false
# Max WhatsApp messages sent per campaign run.
WHATSAPP_DAILY_LIMIT=100

# General Settings
ENVIRONMENT=production  # development or production
DEBUG=False
LOG_LEVEL=INFO
# Public URL of this deployment, used to embed email open-tracking pixels.
# e.g. https://marketingbot-production-d824.up.railway.app
PUBLIC_BASE_URL=

# Scheduler Settings
SCHEDULER_TIMEZONE=Asia/Dhaka
SCHEDULER_MODE=lead_collection
ENABLE_LEAD_COLLECTION=true
ENABLE_BD_EDUCATION_COLLECTION=false
ENABLE_USA_LOCAL_BUSINESS_COLLECTION=true
USA_LOCAL_BUSINESS_INTERVAL_MINUTES=120
USA_LOCAL_BUSINESS_LOCATIONS_PER_RUN=12
USA_LOCAL_BUSINESS_RESULTS_PER_LOCATION=250
ENABLE_MARKETING_JOBS=false
ENABLE_REPORTING_JOBS=false

# Heroku
PORT=5000
